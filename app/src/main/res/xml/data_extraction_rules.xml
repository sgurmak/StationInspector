<?xml version="1.0" encoding="utf-8"?>
<!--
    Inspection data (stations, coordinates, photo paths, preferences) is
    sensitive operational data and must not leave the device. Exclude
    everything from both cloud backup and device-to-device transfer.
    Pairs with android:allowBackup="false" for pre-Android-12 devices.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
